---
import { profileConfig, siteConfig } from "../config";

// Note: profileConfig is now a multilingual object (Record<string, ProfileConfig>)
// Components should use getProfileConfig(lang) from profile-utils.ts to get the correct language version
---

<script is:inline define:vars={{ profileConfig, siteConfig }}>
  window.profileConfig = profileConfig;
  window.siteConfig = siteConfig;
</script>