---
import { Icon } from "astro-icon/components";
import { getSupportedLanguages } from "../config";
import { i18n } from "../i18n/translation";
import I18nKey from "../i18n/i18nKey";
import { getSiteDefaultLanguage, getLanguageUrl } from "../utils/site-language-utils";
import { getLanguageFromPath, removeLanguageFromPath } from "../utils/language-utils";

const supportedLanguages = getSupportedLanguages();
const defaultLang = getSiteDefaultLanguage();

// Initial SSR values. Client-side script will refresh these after Swup navigation.
const currentPath = Astro.url.pathname;
const currentLang = getLanguageFromPath(currentPath);
const basePath = removeLanguageFromPath(currentPath);
---

<div class="relative group">
    <button 
        class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90 flex items-center justify-center"
        aria-label={i18n(I18nKey.languageSelector)}
        id="language-selector"
    >
        <Icon name="material-symbols:language" size={20} />
    </button>
    
    <div 
        class="language-dropdown absolute right-0 top-12 bg-[var(--card-bg)] border border-[var(--line-divider)] rounded-lg shadow-lg p-2 min-w-[150px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
        id="language-dropdown"
    >
        {Object.entries(supportedLanguages).map(([langKey, langInfo]) => {
            const isActive = currentLang === langKey;
            const href = getLanguageUrl(langKey, basePath);
            
            return (
                <a
                    href={href}
                    data-target-lang={langKey}
                    class={`language-link flex items-center px-3 py-2 rounded-md transition-colors ${
                        isActive 
                            ? 'bg-[var(--primary)] text-white' 
                            : 'hover:bg-[var(--btn-plain-bg-hover)] text-[var(--primary)]'
                    }`}
                    aria-current={isActive ? 'page' : undefined}
                >
                    <span class="mr-2 text-lg">{langInfo.flag}</span>
                    <span class="text-sm font-medium">{langInfo.name}</span>
                </a>
            );
        })}
    </div>
</div>

<style>
    .language-dropdown {
        backdrop-filter: blur(10px);
    }
    
    .group:hover .language-dropdown {
        opacity: 1;
        visibility: visible;
    }
</style>

<script>
    import { getLanguageUrl } from '../utils/site-language-utils';
    import { getLanguageFromPath, removeLanguageFromPath } from '../utils/language-utils';

    function updateLanguageLinks(dropdown: HTMLElement) {
        const currentPath = window.location.pathname;
        const currentLang = getLanguageFromPath(currentPath);
        const basePath = removeLanguageFromPath(currentPath);
        const languageLinks = dropdown.querySelectorAll<HTMLAnchorElement>('a[data-target-lang]');

        languageLinks.forEach((link) => {
            const targetLang = link.dataset.targetLang;
            if (!targetLang) return;

            const href = getLanguageUrl(targetLang, basePath);
            const isActive = currentLang === targetLang;

            link.href = href;
            link.setAttribute('aria-current', isActive ? 'page' : 'false');
            link.classList.toggle('bg-[var(--primary)]', isActive);
            link.classList.toggle('text-white', isActive);
            link.classList.toggle('hover:bg-[var(--btn-plain-bg-hover)]', !isActive);
            link.classList.toggle('text-[var(--primary)]', !isActive);
        });
    }

    function initLanguageSelector() {
        const button = document.getElementById('language-selector');
        const dropdown = document.getElementById('language-dropdown');
        
        if (!button || !dropdown) return;

        updateLanguageLinks(dropdown);
        
        let isOpen = false;
        
        const closeDropdown = () => {
            isOpen = false;
            dropdown.classList.add('opacity-0', 'invisible');
            dropdown.classList.remove('opacity-100', 'visible');
        };

        if (!button.dataset.languageSelectorBound) {
            button.dataset.languageSelectorBound = 'true';
            button.addEventListener('click', (e) => {
                e.stopPropagation();
                updateLanguageLinks(dropdown);
                isOpen = !isOpen;
                
                if (isOpen) {
                    dropdown.classList.add('opacity-100', 'visible');
                    dropdown.classList.remove('opacity-0', 'invisible');
                } else {
                    closeDropdown();
                }
            });
        }

        const languageLinks = dropdown.querySelectorAll<HTMLAnchorElement>('a[data-target-lang]');
        languageLinks.forEach((link) => {
            if (link.dataset.languageSelectorBound) return;
            link.dataset.languageSelectorBound = 'true';

            link.addEventListener('click', (e) => {
                e.preventDefault();
                updateLanguageLinks(dropdown);
                window.location.href = link.href;
            });
        });
        
        if (!document.body.dataset.languageSelectorOutsideBound) {
            document.body.dataset.languageSelectorOutsideBound = 'true';
            document.addEventListener('click', (e) => {
                const target = e.target as Element;
                if (!button.contains(target) && !dropdown.contains(target)) {
                    closeDropdown();
                }
            });
        }
        
        if (!document.body.dataset.languageSelectorEscapeBound) {
            document.body.dataset.languageSelectorEscapeBound = 'true';
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && isOpen) {
                    closeDropdown();
                    button.focus();
                }
            });
        }

        if ((window as any).swup?.hooks && !(window as any).__languageSelectorSwupBound) {
            (window as any).__languageSelectorSwupBound = true;
            (window as any).swup.hooks.on('content:replace', () => {
                const currentDropdown = document.getElementById('language-dropdown');
                if (currentDropdown) {
                    updateLanguageLinks(currentDropdown as HTMLElement);
                }
            });
        }
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initLanguageSelector, { once: true });
    } else {
        initLanguageSelector();
    }
    
    document.addEventListener('astro:page-load', initLanguageSelector);
    window.addEventListener('popstate', () => {
        const dropdown = document.getElementById('language-dropdown');
        if (dropdown) updateLanguageLinks(dropdown as HTMLElement);
    });
</script>
