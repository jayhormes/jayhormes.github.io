---

import { render } from "astro:content";
import Markdown from "../components/misc/Markdown.astro";
import { siteConfig } from "../config";
import { getSpecByLangAndName } from "../utils/spec-utils";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSiteDefaultLanguage } from "../utils/site-language-utils";

// For root pages, use the site's configured default language
const currentLang = getSiteDefaultLanguage();

const projectsPost = await getSpecByLangAndName("projects", currentLang);

if (!projectsPost) {
	throw new Error("Projects page content not found");
}

const { Content } = await render(projectsPost);
---
<MainGridLayout title={i18n(I18nKey.projects, currentLang)} description={i18n(I18nKey.projects, currentLang)} banner={siteConfig.pages?.projects?.src} lang={currentLang}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>
